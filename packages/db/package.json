{
  "name": "@toolman/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "demo:chat": "bash scripts/run-with-electron-node.sh scripts/demo-chat-persistence.ts",
    "test:p2p-schema": "bash scripts/run-with-electron-node.sh scripts/p2p-schema-smoke.ts",
    "test:auth-schema": "bash scripts/run-with-electron-node.sh scripts/auth-schema-smoke.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.44.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
