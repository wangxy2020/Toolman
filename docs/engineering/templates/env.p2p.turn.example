# Copy to repo root as .env.p2p.turn (gitignored).
# Dual-instance dev loads this via scripts/p2p-community-env.sh.
# Packaged / RC1 prep: pnpm rc1:wan-prep
#
# --- Xirsys (recommended — ephemeral TURN credentials at startup) ---
TOOLMAN_P2P_XIRSYS_PATH=https://global.xirsys.net
TOOLMAN_P2P_XIRSYS_IDENT=toolman
TOOLMAN_P2P_XIRSYS_SECRET=
TOOLMAN_P2P_XIRSYS_CHANNEL=channelxmq7hfz9
#
# --- Static TURN (alternative) ---
# Public test relay (Metered OpenRelay — dev / RC1 WAN smoke only, not for production GA):
# TOOLMAN_P2P_TURN_URL=turn:staticauth.openrelay.metered.ca:80,turn:staticauth.openrelay.metered.ca:443,turns:staticauth.openrelay.metered.ca:443
# TOOLMAN_P2P_TURN_USERNAME=openrelayproject
# TOOLMAN_P2P_TURN_CREDENTIAL=openrelayprojectsecret
#
# Or copy the full ICE file directly:
#   cp docs/engineering/templates/p2p-network.openrelay.json \\
#      "$HOME/Library/Application Support/Toolman-RC1/p2p/network.json"
#
# Staging production TURN (cross-NAT RC1 signoff — get secret from ops):
# TOOLMAN_P2P_TURN_URL=turn:turn.toolman.app:3478?transport=udp
# TOOLMAN_P2P_TURN_USERNAME=toolman
# TOOLMAN_P2P_TURN_CREDENTIAL=
