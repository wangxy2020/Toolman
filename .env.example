# Copy to `.env.local` in the repository root for local development:
#   cp .env.example .env.local
#
# Production template: `.env.production.example` (see docs/engineering/PRODUCTION_CONFIG.md)
#
# Restart `pnpm --filter @toolman/desktop dev` after changes.

# --- Auth build region (optional) ---
# TOOLMAN_AUTH_BUILD_REGION=global

# --- Domestic auth (CN) dev shortcuts ---
# Authing dev mode: OTP fixed code 123456; WeChat/Douyin use local dev accounts.
# TOOLMAN_AUTHING_DEV_MODE=1
# Legacy Tencent / WeChat dev shortcuts (used when Authing is not configured):
TOOLMAN_TENCENT_SMS_DEV_MODE=1
TOOLMAN_WECHAT_DEV_MODE=1

# --- Authing (CN, recommended) ---
# TOOLMAN_AUTHING_APP_ID=          # 应用 ID（Authing 控制台 → 应用 → 应用 ID）
# TOOLMAN_AUTHING_USER_POOL_ID=    # 用户池 ID（与应用 ID 不同时必填；控制台 → 用户池 → 用户池 ID）
# TOOLMAN_AUTHING_APP_SECRET=      # 应用 Secret（AuthenticationClient）
# TOOLMAN_AUTHING_USER_POOL_SECRET= # 用户池密钥（Management API 拉角色；登录后亦可用用户 token 拉角色）
# TOOLMAN_AUTHING_APP_HOST=https://your-app.authing.cn  # 应用认证域名（非用户池显示名称）
# TOOLMAN_AUTHING_OAUTH_CALLBACK_PORT=42873
# TOOLMAN_AUTHING_WECHAT_PROVIDER=wechat:pc
# TOOLMAN_AUTHING_DOUYIN_PROVIDER=douyin
# OTP validity in seconds (default 120 = 2 minutes)
# TOOLMAN_AUTHING_OTP_TTL_SECONDS=120

# --- Domestic auth (CN) legacy Tencent / WeChat ---
# TOOLMAN_TENCENT_SECRET_ID=
# TOOLMAN_TENCENT_SECRET_KEY=
# TOOLMAN_TENCENT_SMS_SDK_APP_ID=
# TOOLMAN_TENCENT_SMS_SIGN_NAME=
# TOOLMAN_TENCENT_SMS_TEMPLATE_ID=
# TOOLMAN_WECHAT_OPEN_APP_ID=
# TOOLMAN_WECHAT_OPEN_APP_SECRET=

# --- International auth (Firebase) ---
# Required for email / Google / Apple login.
# TOOLMAN_FIREBASE_API_KEY=
# TOOLMAN_FIREBASE_AUTH_DOMAIN=
# TOOLMAN_FIREBASE_PROJECT_ID=
# TOOLMAN_FIREBASE_APP_ID=

# --- P2P / WAN ---
# See docs/engineering/PRODUCTION_CONFIG.md
#
# Xirsys (recommended — baked into release DMG via .env.p2p.turn at build time):
# TOOLMAN_P2P_XIRSYS_PATH=https://global.xirsys.net
# TOOLMAN_P2P_XIRSYS_IDENT=toolman
# TOOLMAN_P2P_XIRSYS_SECRET=
# TOOLMAN_P2P_XIRSYS_CHANNEL=channelxmq7hfz9
# Template: docs/engineering/templates/env.p2p.turn.example
#
# Dev / WAN smoke test (Metered OpenRelay — public credentials, not for production GA):
# TOOLMAN_P2P_TURN_URL=turn:staticauth.openrelay.metered.ca:80,turn:staticauth.openrelay.metered.ca:443,turns:staticauth.openrelay.metered.ca:443
# TOOLMAN_P2P_TURN_USERNAME=openrelayproject
# TOOLMAN_P2P_TURN_CREDENTIAL=openrelayprojectsecret
# Template: docs/engineering/templates/p2p-network.openrelay.json
# Install:   cp docs/engineering/templates/env.p2p.turn.example .env.p2p.turn && pnpm rc1:wan-prep
#
# Staging production TURN:
# TOOLMAN_P2P_TURN_URL=turn:turn.toolman.app:3478?transport=udp
# TOOLMAN_P2P_TURN_USERNAME=toolman
# TOOLMAN_P2P_TURN_CREDENTIAL=
