# Copy to `.env.local` in the repository root for local development:
#   cp .env.example .env.local
#
# Restart `pnpm --filter @toolman/desktop dev` after changes.

# --- Auth build region (optional) ---
# TOOLMAN_AUTH_BUILD_REGION=global

# --- Domestic auth (CN) dev shortcuts ---
# SMS verification uses fixed code 123456 when dev mode is enabled.
TOOLMAN_TENCENT_SMS_DEV_MODE=1
# WeChat OAuth uses a local dev account when dev mode is enabled.
TOOLMAN_WECHAT_DEV_MODE=1

# --- Domestic auth (CN) production credentials ---
# TOOLMAN_TENCENT_SECRET_ID=
# TOOLMAN_TENCENT_SECRET_KEY=
# TOOLMAN_TENCENT_SMS_SDK_APP_ID=
# TOOLMAN_TENCENT_SMS_SIGN_NAME=
# TOOLMAN_TENCENT_SMS_TEMPLATE_ID=
# TOOLMAN_WECHAT_OPEN_APP_ID=
# TOOLMAN_WECHAT_OPEN_APP_SECRET=

# --- International auth (Firebase) ---
# Required for email / Google / Apple login.
# TOOLMAN_FIREBASE_API_KEY=
# TOOLMAN_FIREBASE_AUTH_DOMAIN=
# TOOLMAN_FIREBASE_PROJECT_ID=
# TOOLMAN_FIREBASE_APP_ID=
