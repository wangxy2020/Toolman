{
  "name": "toolman",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/wangxy2020/Toolman.git"
  },
  "description": "AI productivity client — multi-model chat, knowledge, plugins, and more",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:p2p": "bash scripts/build-p2p-native.sh",
    "build:libp2p": "bash scripts/build-libp2p-native.sh",
    "build:p2p:macos": "bash scripts/build-p2p-macos.sh",
    "build:community-hub": "bash scripts/build-community-hub.sh",
    "build:excel-mcp-server": "bash scripts/build-excel-mcp-server.sh",
    "build:docx-core": "bash scripts/build-docx-core.sh",
    "build:docx-mcp-server": "bash scripts/build-docx-mcp-server.sh",
    "p2p:dual-init": "bash scripts/p2p-dual-instance-init.sh",
    "dev:p2p:a": "bash scripts/p2p-dev-user-a.sh",
    "dev:p2p:b": "bash scripts/p2p-dev-user-b.sh",
    "verify:folders": "bash scripts/verify-toolman-folders.sh",
    "verify:folders:a": "bash scripts/verify-toolman-folders.sh /tmp/toolman-node-b 用户1",
    "verify:folders:b": "bash scripts/verify-toolman-folders.sh /tmp/toolman-p2p-b 用户2",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:eslint": "eslint .",
    "test": "turbo run test",
    "smoke": "bash scripts/smoke-critical-paths.sh",
    "rc1:preflight": "bash scripts/rc1-preflight.sh",
    "rc1:build": "bash scripts/build-rc1-desktop.sh",
    "rc1:install-p2p-network": "bash scripts/rc1-install-p2p-network.sh",
    "rc1:wan-prep": "bash scripts/rc1-wan-prep.sh",
    "rc1:dogfood-day": "bash scripts/rc1-dogfood-day.sh",
    "dev:coturn": "bash scripts/dev-coturn-up.sh",
    "rc1:publish-staging": "bash scripts/rc1-publish-staging.sh",
    "rc1:wan-10-checklist": "bash scripts/p2p-wan-10-peer-checklist.sh",
    "release:desktop": "bash scripts/build-desktop-release.sh",
    "release:print-env": "node scripts/print-toolman-release-env.mjs",
    "release:desktop:publish": "bash scripts/publish-update-feed.sh",
    "release:verify-feed": "bash scripts/verify-update-feed.sh",
    "licenses:generate": "node scripts/generate-third-party-notices.mjs",
    "provenance:generate": "node scripts/write-build-provenance.mjs",
    "db:generate": "pnpm --filter @toolman/db generate",
    "db:migrate": "pnpm --filter @toolman/db migrate",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "nanoid": "3.3.12",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
